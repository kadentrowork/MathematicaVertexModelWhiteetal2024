      RowBox[{"[", 
       RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"Calculate", " ", "area", " ", "for", " ", "each", " ", "cell"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cellAreas", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"cellVertices", "=", 
         RowBox[{"firstFrameVertices", "[", 
          RowBox[{"[", 
           RowBox[{"firstFrameVoronoi", "[", 
            RowBox[{"[", 
             RowBox[{"cell", ",", "2"}], "]"}], "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Area", "[", 
         RowBox[{"Polygon", "[", "cellVertices", "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"cell", ",", 
         RowBox[{"Length", "[", "firstFrameVoronoi", "]"}]}], "}"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Find", " ", "the", " ", "cell", " ", "with", " ", "maximum", " ", 
     "area"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"woundNum", "=", 
