      RowBox[{"(", 
       RowBox[{"first", " ", "frame"}], ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"firstFrameVertices", "=", 
     RowBox[{"importedTrajectories", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"firstFrameVoronoi", "=", 
