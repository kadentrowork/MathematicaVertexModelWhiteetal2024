                    RowBox[{"cell", ",", "2"}], "]"}], "]"}], "]"}]}], "]"}], 
                    "+", "1"}]}], "]"}], "]"}], "]"}], "]"}]}], "}"}], 
                   "]"}]}], "}"}], "]"}], ",", 
