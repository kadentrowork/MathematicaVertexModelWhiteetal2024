       RowBox[{"x0", "+", "d"}], ",", " ", "y0"}], "}"}]}], " ", ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nCells", " ", "=", " ", "280"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"scale", " ", "=", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"41.3083", "/", 
       RowBox[{"(", 
        RowBox[{"Pi", "*", "a", "*", 
         RowBox[{"b", "/", "nCells"}]}], ")"}]}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "one", " ", "length", " ", "unit", " ", "equals", " ", "scale", "*", 
     "micron"}], " ", "*)"}], "\n", 
