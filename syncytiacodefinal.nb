Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Extract", " ", "all", " ", "individual", " ", "curves"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"allSyncCurves", "=", 
     RowBox[{"processedData", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"All", " ", "sync", " ", "curves"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"allContCurves", "=", 
     RowBox[{"processedData", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"All", " ", "cont", " ", "curves"}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Plot", " ", "all", " ", "curves"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Join", "[", 
      RowBox[{"allSyncCurves", ",", "allContCurves"}], "]"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Directive", "[", 
           RowBox[{"Red", ",", 
            RowBox[{"Opacity", "[", 
             RowBox[{"i", "/", 
              RowBox[{"Length", "[", "allSyncCurves", "]"}]}], "]"}]}], "]"}],
           ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Length", "[", "allSyncCurves", "]"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Directive", "[", 
           RowBox[{"Blue", ",", 
            RowBox[{"Opacity", "[", 
             RowBox[{"i", "/", 
              RowBox[{"Length", "[", "allContCurves", "]"}]}], "]"}]}], "]"}],
           ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
