     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"a", "^", "2"}], "-", 
       RowBox[{"b", "^", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"center", "=", 
     RowBox[{"{", 
      RowBox[{"x0", ",", "y0"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"focus1", "=", 
     RowBox[{"{", 
